#!/usr/bin/env bash
set -euo pipefail

THRESHOLD="${COVERAGE_THRESHOLD:-80}"
ROOT_DIR="$(git rev-parse --show-toplevel 2>/dev/null || true)"
if [[ -z "${ROOT_DIR}" ]]; then
  # Allow running the hook manually before git is initialized.
  ROOT_DIR="$(pwd)"
fi
cd "$ROOT_DIR"

echo "Running unit-test coverage gate (line coverage >= ${THRESHOLD}%)..."
swift test --enable-code-coverage >/dev/null

PROFDATA="$(find .build -type f -name default.profdata | head -n 1 || true)"
if [[ -z "${PROFDATA}" || ! -f "${PROFDATA}" ]]; then
  echo "ERROR: Coverage profile not found (default.profdata)."
  exit 1
fi

TEST_BIN="$(find .build -type f -name '*PackageTests' -perm -111 | head -n 1 || true)"
if [[ -z "${TEST_BIN}" || ! -f "${TEST_BIN}" ]]; then
  echo "ERROR: Package test binary not found under .build."
  exit 1
fi

REPORT_OUTPUT="$(xcrun llvm-cov report "$TEST_BIN" -instr-profile "$PROFDATA" 2>/dev/null || true)"
if [[ -z "${REPORT_OUTPUT}" ]]; then
  echo "ERROR: Unable to generate llvm-cov report."
  exit 1
fi

# TOTAL row format (llvm-cov report):
# TOTAL Regions MissedRegions RegionsCover Functions MissedFunctions FunctionsCover Lines MissedLines LinesCover Branches MissedBranches BranchesCover
# We want LinesCover (field 10).
LINE_COVERAGE="$(printf '%s\n' "$REPORT_OUTPUT" | awk '$1 == "TOTAL" { gsub("%", "", $10); print $10 }' | tail -n 1)"
REGION_COVERAGE="$(printf '%s\n' "$REPORT_OUTPUT" | awk '$1 == "TOTAL" { gsub("%", "", $4); print $4 }' | tail -n 1)"

if [[ -z "${LINE_COVERAGE}" ]]; then
  echo "ERROR: Could not parse TOTAL line coverage from llvm-cov output."
  echo "$REPORT_OUTPUT"
  exit 1
fi

python3 - "$LINE_COVERAGE" "$THRESHOLD" "${REGION_COVERAGE:-}" <<'PY'
import sys

coverage = float(sys.argv[1])
threshold = float(sys.argv[2])
region_coverage = sys.argv[3] if len(sys.argv) > 3 else ""

print(f"Line coverage: {coverage:.2f}% (threshold: {threshold:.2f}%)")
if region_coverage:
    try:
        print(f"Region coverage: {float(region_coverage):.2f}%")
    except ValueError:
        pass
if coverage < threshold:
    print("Coverage gate failed. Commit blocked.")
    sys.exit(1)

print("Coverage gate passed.")
PY
